/*
 * TEST KEYMAP — for identifying key positions in Keymap Editor
 *
 * Press each physical key in a text editor and note the character it outputs.
 * Find that character in the chart below — that's the matching box in the UI.
 * The LOWER key does not output a character (it activates the LOWER layer).
 * Use LOWER+Z for left half bootloader, LOWER+bootloader key for right half.
 *
 * .-----------------------------------------------------------------------.
 * | 1  | 2  | 3  | 4  | 5  | 6  | 7  | 8  | 9  | 0  | a  | b  | c  | d  |
 * | e  | f  | g  | h  | i  | j  | k  | l  | m  | n  | o  | p  | q  | r  |
 * | s  | t  | u  | v  | w  | x  | y  | z  | -  | =  | [  | ]  | \  | ;  |
 * | '  | `  | ,  | .  | /  | !  | @  | #  | $  | %  | ^  | &  | *  | (  |
 * | )  | _  | +  | {  | }  | |  |LWR | :  | "  | ~  | <  | >  | ?  |TAB |
 * .-----------------------------------------------------------------------.
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>

#define DEFAULT 0
#define LOWER   1
#define RAISE   2

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
&kp N1        &kp N2        &kp N3        &kp N4        &kp N5        &kp N6        &kp N7                                     &kp N8        &kp N9        &kp N0        &kp A         &kp B         &kp C         &kp D
&kp E         &kp F         &kp G         &kp H         &kp I         &kp J         &kp K                                      &kp L         &kp M         &kp N         &kp O         &kp P         &kp Q         &kp R
&kp S         &kp T         &kp U         &kp V         &kp W         &kp X         &kp Y                                      &kp Z         &kp MINUS     &kp EQUAL     &kp LBKT      &kp RBKT      &kp BSLH      &kp SEMI
&kp SQT       &kp GRAVE     &kp COMMA     &kp DOT       &kp SLASH     &kp LS(N1)                   &kp LS(N2)   &kp LS(N3)                   &kp LS(N4)    &kp LS(N5)    &kp LS(N6)    &kp LS(N7)    &kp LS(N8)    &kp LS(N9)
&kp LS(N0)    &kp LS(MINUS) &kp LS(EQUAL) &kp LS(LBKT)  &kp LS(RBKT)               &kp LS(BSLH)  &mo LOWER    &kp LS(SEMI)  &kp LS(SQT)                  &kp LS(GRAVE) &kp LS(COMMA) &kp LS(DOT)   &kp LS(SLASH) &kp TAB
            >;
        };

        lower_layer {
            bindings = <
&kp F11  &kp F1       &kp F2      &kp F3  &kp F4  &kp F5  &none                        &none          &kp F6  &kp F7  &kp F8  &kp F9  &kp F10  &kp F12
&none    &none        &none       &none   &none   &none   &none                        &none          &none   &none   &none   &none   &none    &none
&none    &none        &none       &none   &kp F1  &kp F2  &none                        &none          &none   &none   &none   &none   &none    &none
&trans   &bootloader  &sys_reset  &none   &none   &none          &none   &none                        &none   &none   &none   &none   &none    &trans
&trans   &none        &none       &trans  &trans          &none  &trans  &kp LC(LEFT)  &kp LC(RIGHT)          &trans  &none   &none   &none    &trans
            >;
        };

        raise_layer {
            bindings = <
&none   &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &none  &bt BT_CLR                  &none  &none  &none   &none  &none        &none       &none
&none   &none         &none         &none         &none         &none  &none                       &none  &none  &none   &none  &none        &none       &none
&none   &none         &none         &none         &none         &none  &none                       &none  &none  &none   &none  &none        &none       &none
&trans  &none         &none         &none         &none         &none              &none   &none          &none  &none   &none  &bootloader  &sys_reset  &trans
&trans  &none         &none         &trans        &trans               &none       &trans  &trans  &none         &trans  &none  &none        &none       &trans
            >;
        };
    };
};
