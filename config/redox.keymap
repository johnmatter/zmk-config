/*
 * TEST KEYMAP — for identifying key positions in Keymap Editor
 *
 * Press each physical key in a text editor and note the character it outputs.
 * Find that character in the chart below — that's the matching box in the UI.
 * The LOWER key does not output a character (it activates the LOWER layer).
 * Use LOWER+Z for left half bootloader, LOWER+bootloader key for right half.
 *
 * .-----------------------------------------------------------------------.
 * | 1  | 2  | 3  | 4  | 5  | 6  | 7  | 8  | 9  | 0  | a  | b  | c  | d  |
 * | e  | f  | g  | h  | i  | j  | k  | l  | m  | n  | o  | p  | q  | r  |
 * | s  | t  | u  | v  | w  | x  | y  | z  | -  | =  | [  | ]  | \  | ;  |
 * | '  | `  | ,  | .  | /  | !  | @  | #  | $  | %  | ^  | &  | *  | (  |
 * | )  | _  | +  | {  | }  | |  |LWR | :  | "  | ~  | <  | >  | ?  |TAB |
 * .-----------------------------------------------------------------------.
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>

#define DEFAULT 0
#define LOWER   1
#define RAISE   2

/ {
    macros {
        vimnexttab: vimnexttab {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp G &kp T>;
            label = "VIMNEXTTAB";
        };

        vimprevtab: vimprevtab {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp G &kp LS(T)>;
            label = "VIMPREVTAB";
        };

        macOS_screenshot_clipboard: macOS_screenshot_window {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LG(LS(LC(NUMBER_4)))>;
            label = "MACOS_SCREENSHOT_WINDOW";
        };

        macOS_screenshot: macOS_screenshot {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LG(LS(NUMBER_4))>;
            label = "MACOS_SCREENSHOT";
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
&kp ESCAPE      &kp NUMBER_1  &kp NUMBER_2  &kp NUMBER_3  &kp NUMBER_4  &kp N5                                                                                    &kp NUMBER_6  &kp N7  &kp N8     &kp N9      &kp N0         &kp MINUS
&kp GRAVE       &kp Q         &kp W         &kp E         &kp R         &kp T   &macOS_screenshot_clipboard                                    &none              &kp Y         &kp U   &kp I      &kp O       &kp P          &kp BACKSLASH
&kp TAB         &kp A         &kp S         &kp D         &kp F         &kp G   &macOS_screenshot                                              &kp ENTER          &kp H         &kp J   &kp K      &kp L       &kp SEMICOLON  &kp SQT
&kp LEFT_SHIFT  &kp Z         &kp X         &kp C         &kp V         &kp B   &kp LCTRL                    &kp LEFT_ALT    &kp LEFT_BRACKET  &kp RIGHT_BRACKET  &kp N         &kp M   &kp COMMA  &kp PERIOD  &kp SLASH      &kp RIGHT_SHIFT
&kp LCTRL       &kp LEFT_ALT  &none         &none         &mo 2                 &kp LEFT_GUI                 &mo 1           &kp BACKSPACE     &kp SPACE                        &mo 1   &none      &none       &kp RALT       &kp RCTRL
            >;
        };

        lower_layer {
            bindings = <
&kp LG(LC(F))  &kp F1        &kp F2        &kp F3        &kp F4        &kp F5                                                         &kp F6         &kp F7            &kp F8         &kp F9         &kp F10        &kp EQUAL
&none          &kp NUMBER_1  &kp NUMBER_2  &kp NUMBER_3  &kp NUMBER_4  &kp N5     &bootloader                          &bootloader    &kp NUMBER_6   &kp NUMBER_7      &kp N8         &kp N9         &kp N0         &none
&none          &none         &none         &kp F1        &kp F2        &kp ENTER  &none                                &none          &kp LEFT       &kp DOWN          &kp UP_ARROW   &kp RIGHT      &none          &kp GRAVE
&none          &none         &none         &kp F3        &kp F4        &none      &none        &none     &vimprevtab   &vimnexttab    &kp LC(LA(N))  &kp LA(LC(M))     &kp LC(LA(H))  &kp LA(LC(X))  &kp BACKSLASH  &kp ENTER
&none          &none         &none         &none         &to 2                    &none        &trans    &kp LC(LEFT)  &kp LC(RIGHT)                 &kp K_PLAY_PAUSE  &kp K_PREV     &kp K_NEXT     &none          &none
            >;
        };

        raise_layer {
            bindings = <
&none   &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &none                                  &bt BT_CLR  &none   &none  &none        &none       &none
&none   &none         &none         &none         &none         &none  &none                    &none  &none       &none   &none  &none        &none       &none
&none   &none         &none         &kp F5        &kp F6        &none  &none                    &none  &none       &none   &none  &none        &none       &none
&none   &none         &trans        &none         &none         &none  &none  &none     &none   &none  &none       &none   &none  &bootloader  &sys_reset  &trans
&trans  &none         &none         &trans        &to 0                &none  &trans    &trans  &none              &trans  &none  &none        &none       &trans
            >;
        };
    };
};
